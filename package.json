{
  "name": "hive",
  "productName": "Hive",
  "version": "0.1.0",
  "description": "Hive — centralized Buzz-compatible server. Stores E2E-encrypted messages and relays voice/video.",
  "main": "out/main/index.js",
  "type": "module",
  "private": true,
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "libsodium-wrappers-sumo": "^0.7.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/libsodium-wrappers-sumo": "^0.7.8",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.2.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.13"
  },
  "build": {
    "appId": "com.hive.app",
    "productName": "Hive",
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/*.node"
    ]
  }
}
